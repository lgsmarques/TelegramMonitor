# Obtenha api_id e api_hash em https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Gere rodando: python generate_session.py
TELEGRAM_SESSION_STRING=

# Discord > Canal > Editar canal > Integrações > Webhooks > Criar webhook > copiar URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Keywords separadas por vírgula (case-insensitive)
# Exemplo: iphone,samsung,rtx,desconto,oferta
KEYWORDS=

# Canais do Telegram para monitorar (username sem @, separados por vírgula)
# Deixe vazio para monitorar TODOS os canais que você participa
TELEGRAM_CHANNELS=

# Segundos de cooldown entre alertas repetidos do mesmo canal+keyword (padrão: 60)
COOLDOWN_SECONDS=60
